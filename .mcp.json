{
  "mcpServers": {
    "awslabs-cloudwatch-mcp-server": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "AWS_PROFILE=blackboxduty",
        "-e",
        "AWS_REGION=ca-central-1",
        "-e",
        "FASTMCP_LOG_LEVEL=ERROR",
        "-v",
        "${HOME}/.aws:/app/.aws:ro",
        "public.ecr.aws/awslabs-mcp/awslabs/cloudwatch-mcp-server:latest"
      ],
      "env": {}
    }
  }
}

